# API server URL (Vite proxy handles this in dev, set for production builds)
VITE_API_URL=

# Dedicated API URL for Capacitor/TestFlight builds
VITE_NATIVE_API_URL=

# Stripe price IDs (from Stripe Dashboard → Products)
VITE_STRIPE_PRO_PRICE_ID=
VITE_STRIPE_PREMIUM_PRICE_ID=

# Dev server port (optional, defaults to 5173)
VITE_PORT=
VITE_EMAIL_VERIFICATION_ENABLED=false
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=
