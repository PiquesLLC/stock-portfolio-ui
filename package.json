{
  "name": "stock-portfolio-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "smoke:test": "node scripts/smoke-test.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "build:cap": "tsc -b && vite build --mode capacitor",
    "cap:sync": "npm run build:cap && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capgo/capacitor-native-biometric": "^8.4.2",
    "@capgo/native-purchases": "^8.3.5",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^3.0.5",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plaid-link": "^4.1.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.12",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
